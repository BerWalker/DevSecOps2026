FLASK_SECRET_KEY=super-secret-key

# Auth database (postgres-auth)
AUTH_POSTGRES_USER=auth
AUTH_POSTGRES_PASSWORD=auth
AUTH_POSTGRES_DB=auth_db
AUTH_POSTGRES_PORT=5432

# Campaign database (postgres-campaign)
CAMPAIGN_POSTGRES_USER=campaign
CAMPAIGN_POSTGRES_PASSWORD=campaign
CAMPAIGN_POSTGRES_DB=campaign_db
CAMPAIGN_POSTGRES_PORT=5433

# Analytics database (postgres-analytics)
ANALYTICS_POSTGRES_USER=analytics
ANALYTICS_POSTGRES_PASSWORD=analytics
ANALYTICS_POSTGRES_DB=analytics_db
ANALYTICS_POSTGRES_PORT=5434

# Local development (full URLs; Compose overrides DATABASE_URL per service)
AUTH_DATABASE_URL=postgresql+psycopg://auth:auth@localhost:5432/auth_db
CAMPAIGN_DATABASE_URL=postgresql+psycopg://campaign:campaign@localhost:5433/campaign_db
ANALYTICS_DATABASE_URL=postgresql+psycopg://analytics:analytics@localhost:5434/analytics_db

JWT_SECRET_KEY=super-secret-key
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_GRACE_SECONDS=300

# API Gateway (public entry point — auth and email are accessed only via gateway)
GATEWAY_PORT=5000
GATEWAY_URL=http://localhost:5000

# Internal auth container port (not exposed on host when using Docker Compose)
AUTH_SERVICE_PORT=5001
CAMPAIGN_SERVICE_PORT=5002
ANALYTICS_SERVICE_PORT=5003
EMAIL_SERVICE_PORT=5010

# Shared secret for service-to-service calls (campaign internal API, email, auth introspect)
INTERNAL_API_KEY=change-me-internal-key

# Public base URL for per-target tracking links (gateway)
TRACKING_BASE_URL=http://localhost:5000

# Email service (SMTP via Gmail)
GMAIL_FROM=your@gmail.com
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587